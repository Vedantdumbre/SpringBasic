<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="carSpecification" class="car.example.constructor.injection.Specification"> <!-- we tell that we want to manage this container by spring-->
        <property name="make" value="Volvo" />
        <property name="model" value="Z+" />
    </bean>
    <bean id="myCar" class="car.example.constructor.injection.Car">
        <constructor-arg ref="carSpecification"/>
    </bean>
</beans>

